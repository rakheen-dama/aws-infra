{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "InfraServices",
      "Effect": "Allow",
      "Action": [
        "ec2:*",
        "ecs:*",
        "ecr:*",
        "elasticloadbalancing:*",
        "rds:*",
        "elasticache:*",
        "logs:*",
        "cloudwatch:*",
        "sns:*",
        "application-autoscaling:*",
        "servicediscovery:*",
        "acm:*",
        "route53:*",
        "sts:GetCallerIdentity"
      ],
      "Resource": "*"
    },
    {
      "Sid": "ProjectSecrets",
      "Effect": "Allow",
      "Action": "secretsmanager:*",
      "Resource": "arn:aws:secretsmanager:*:*:secret:kazi/*"
    },
    {
      "Sid": "SecretsAccountLevel",
      "Effect": "Allow",
      "Action": [
        "secretsmanager:ListSecrets",
        "secretsmanager:GetRandomPassword"
      ],
      "Resource": "*"
    },
    {
      "Sid": "ProjectBuckets",
      "Effect": "Allow",
      "Action": "s3:*",
      "Resource": [
        "arn:aws:s3:::binarymash-*",
        "arn:aws:s3:::binarymash-*/*",
        "arn:aws:s3:::kazi-*",
        "arn:aws:s3:::kazi-*/*"
      ]
    },
    {
      "Sid": "S3List",
      "Effect": "Allow",
      "Action": "s3:ListAllMyBuckets",
      "Resource": "*"
    },
    {
      "Sid": "TerraformStateLock",
      "Effect": "Allow",
      "Action": "dynamodb:*",
      "Resource": "arn:aws:dynamodb:*:*:table/binarymash-terraform-locks"
    },
    {
      "Sid": "SsmAmiLookupAndBastionSessions",
      "Effect": "Allow",
      "Action": [
        "ssm:GetParameter",
        "ssm:GetParameters",
        "ssm:StartSession",
        "ssm:TerminateSession",
        "ssm:ResumeSession",
        "ssm:DescribeSessions",
        "ssm:DescribeInstanceInformation"
      ],
      "Resource": "*"
    },
    {
      "Sid": "SesIdentitySetup",
      "Effect": "Allow",
      "Action": [
        "ses:*"
      ],
      "Resource": "*"
    }
  ]
}
